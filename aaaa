-- // 7. Calculations Engine & Targeting Algorithms
local function GetClosestPlayer()
    local ClosestPlayer = nil
    local ShortestDistance = math.huge

    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character and Player.Character:FindFirstChild(Config.LockPart) and Player.Character:FindFirstChildOfClass("Humanoid") and Player.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            local Pos, OnScreen = Camera:WorldToViewportPoint(Player.Character[Config.LockPart].Position)
            if OnScreen then
                local Distance = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if Distance < ShortestDistance and Distance <= Config.FovRadius then
                    ClosestPlayer = Player
                    ShortestDistance = Distance
                end
            end
        end
    end
    return ClosestPlayer
end

-- Keyboard Input Bind Observers
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Config.AimbotKey then ToggleAimbot()
    elseif input.KeyCode == Config.EspKey then ToggleEsp()
    elseif input.KeyCode == Config.WallhackKey then ToggleWallhack()
    elseif input.KeyCode == Config.AutoShootKey then ToggleAutoShoot()
    elseif input.KeyCode == Config.AntiCheatKey then ToggleAntiCheat()
    elseif input.KeyCode == Config.RapidFireKey then ToggleRapidFire()
    elseif input.KeyCode == Config.MinimizeKey then ToggleMinimize()
    end
end)


-- // 8. Master Performance Rendering Worker Loop
RunService.RenderStepped:Connect(function()
    -- Vector Ring FOV Placement
    if Config.FovEnabled then
        FovCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FovCircle.Visible = true
    else
        FovCircle.Visible = false
    end

    local Target = GetClosestPlayer()

    -- Aimbot Head Lock
    if Config.AimbotEnabled and Target and Target.Character and Target.Character:FindFirstChild(Config.LockPart) then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character[Config.LockPart].Position)
    end

    -- Autofarm / Autokill Thread Execution (Maintains position behind target root)
    if Config.AutoFarmEnabled and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local TargetHRP = Target.Character.HumanoidRootPart
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = TargetHRP.CFrame * CFrame.new(0, 0, 3)
        end
    end

    -- Auto Shoot Tool Trigger Simulation
    if Config.AutoShootEnabled and Target then
        VirtualInputManager:FireMouseButtonEventRightlick(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2, 0, true, game, 1)
        task.wait(0.07)
        VirtualInputManager:FireMouseButtonEventRightlick(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2, 0, true, game, 1)
    end

    -- Rapid Fire Performance Engine Mod
    if Config.RapidFireEnabled then
        local Tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if Tool then
            -- Bypasses classic click cooldown attributes via local registry activation flags
            Tool:Activate()
            if Tool:FindFirstChild("Activated") then
                Tool.Activated:Fire()
            end
        end
    end

    -- Anti-Cheat State Safety Sandbox
    if Config.AntiCheatBypass then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            local hum = LocalPlayer.Character.Humanoid
            if hum.WalkSpeed > 16 then hum.WalkSpeed = 16 end
        end
    end

    -- Visual Highlights (ESP & Wallhacks Rendering Updates)
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character then
            -- Wallhack Highlight Component
            local Highlight = Player.Character:FindFirstChild("VS_Highlight")
            if Config.WallhackEnabled then
                if not Highlight then
                    Highlight = Instance.new("Highlight")
                    Highlight.Name = "VS_Highlight"
                    Highlight.FillColor = Color3.fromRGB(240, 50, 50)
                    Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    Highlight.FillTransparency = 0.45
                    Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    Highlight.Parent = Player.Character
                end
            else
                if Highlight then Highlight:Destroy() end
            end

            -- Overhead Name Label Billboard Components
            local BbEsp = Player.Character:FindFirstChild("VS_Esp")
            if Config.EspEnabled then
                if not BbEsp and Player.Character:FindFirstChild("Head") then
                    BbEsp = Instance.new("BillboardGui")
                    BbEsp.Name = "VS_Esp"
                    BbEsp.AlwaysOnTop = true
                    BbEsp.Size = UDim2.new(0, 100, 0, 30)
                    BbEsp.Adornee = Player.Character.Head
                    BbEsp.StudsOffset = Vector3.new(0, 2.6, 0)
                    
                    local EspText = Instance.new("TextLabel")
                    EspText.Size = UDim2.new(1, 0, 1, 0)
                    EspText.BackgroundTransparency = 1
                    EspText.Text = Player.Name
                    EspText.TextColor3 = Color3.fromRGB(50, 255, 140)
                    EspText.Font = Enum.Font.GothamBold
                    EspText.TextSize = 11
                    EspText.Parent = BbEsp
                    
                    BbEsp.Parent = Player.Character
                end
            else
                if BbEsp then BbEsp:Destroy() end
            end
        end
    end
end)
